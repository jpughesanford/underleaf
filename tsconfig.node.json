{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"]
    },
    "outDir": "out"
  },
  "references": [
    { "path": "./src/shared" }
  ],
  "include": [
    "electron.vite.config.*",
    "electron/**/*.ts",
    "electron/**/*.d.ts"
  ]
}
