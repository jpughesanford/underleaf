{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "out"
  },
  "include": [
    "electron.vite.config.*",
    "electron/**/*.ts",
    "electron/**/*.d.ts"
  ]
}
