{
  "id": "red",
  "name": "Red",
  "dark": false,
  "chrome": {
    "bgApp": "#fce0e7",
    "bgSidebar": "#f8d0dc",
    "bgPanel": "#f1b9ca",
    "bgCard": "#fffaf9",
    "bgCardHover": "#faeae8",
    "bgToolbar": "#2a4a3a",
    "bgInput": "#fffaf9",
    "bgModal": "#fffaf9",
    "bgOverlay": "rgba(42,74,58,0.4)",
    "brand": "#d63f7a",
    "brandDark": "#b32d62",
    "brandHover": "#e0588d",
    "textPrimary": "#2b1218",
    "textSecondary": "#6b3a48",
    "textMuted": "#a08087",
    "textAccent": "#d63f7a",
    "textError": "#b91c1c",
    "textWarning": "#b45309",
    "border": "#e8c4cf",
    "borderLight": "#f3d6df",
    "borderFocus": "#d63f7a",
    "error": "#dc2626",
    "warning": "#d97706",
    "success": "#5fae3f",
    "info": "#4a7bb8",
    "scrollbar": "#e8c4cf",
    "scrollbarHover": "#d4a3b0"
  },
  "theme": {
    "&": {
      "backgroundColor": "#fffaf9",
      "color": "#2b1218"
    },
    ".cm-gutters": {
      "backgroundColor": "#fadde5",
      "color": "#b8949c",
      "borderRightColor": "#ead0d8"
    },
    ".cm-cursor, .cm-dropCursor": {
      "borderLeft": "2px solid #d63f7a"
    },
    "&.cm-focused > .cm-scroller > .cm-selectionLayer .cm-selectionBackground, .cm-selectionBackground, .cm-content ::selection, .cm-searchMatch.cm-searchMatch.cm-searchMatch-selected": {
      "background": "rgba(214,63,122,0.2)"
    },
    "&.cm-focused .cm-matchingBracket, &.cm-focused .cm-nonmatchingBracket": {
      "margin": 0,
      "outline": "1px solid rgba(214,63,122,0.45)"
    },
    ".cm-activeLine": {
      "background": "rgba(214,63,122,0.05)"
    },
    ".cm-activeLineGutter": {
      "backgroundColor": "rgba(214,63,122,0.08)"
    },
    ".cm-selectionMatch.cm-selectionMatch, .cm-searchMatch.cm-searchMatch": {
      "outline": "1px solid rgba(168,118,42,0.32)",
      "margin": 0
    },
    ".cm-foldPlaceholder": {
      "backgroundColor": "rgba(214,63,122,0.12)",
      "borderColor": "rgba(214,63,122,0.35)",
      "color": "#2b1218"
    },
    ".cm-error-line": {
      "backgroundColor": "rgba(185,28,28,0.07)",
      "borderLeft": "3px solid #b91c1c"
    }
  },
  "highlightStyle": {
    ".tok-keyword": { "color": "#b8345a" },
    ".tok-literal": { "color": "#862557" },
    ".tok-typeName": { "color": "#4d7a35" },
    ".tok-invalid": { "color": "#fffaf9", "backgroundColor": "#dc2626" },
    ".tok-string": { "color": "#a87e2c" },
    ".tok-comment": { "fontStyle": "italic", "color": "#a08087" },
    ".tok-attributeValue": { "color": "#5a7d3d", "fontStyle": "italic" },
    ".tok-number": { "color": "#a87e2c" },
    ".tok-link": { "color": "#4a7bb8", "textDecoration": "underline" },
    ".tok-url": { "color": "#4a7bb8" },
    ".tok-strong": { "fontWeight": "bold" }
  }
}
