{
  "id": "green",
  "name": "Green",
  "dark": false,
  "chrome": {
    "bgApp": "#e7f0d8",
    "bgSidebar": "#d6e4c2",
    "bgPanel": "#bcd1a0",
    "bgCard": "#f8fce8",
    "bgCardHover": "#eef5dc",
    "bgToolbar": "#2d3a1e",
    "bgInput": "#f8fce8",
    "bgModal": "#f8fce8",
    "bgOverlay": "rgba(45,58,30,0.4)",
    "brand": "#d63f7a",
    "brandDark": "#b32d62",
    "brandHover": "#e0588d",
    "textPrimary": "#1a2410",
    "textSecondary": "#4a5a35",
    "textMuted": "#8a9d78",
    "textAccent": "#d63f7a",
    "textError": "#b91c1c",
    "textWarning": "#b45309",
    "border": "#c8d8b0",
    "borderLight": "#d8e4c4",
    "borderFocus": "#d63f7a",
    "error": "#dc2626",
    "warning": "#d97706",
    "success": "#5fae3f",
    "info": "#2a5a8a",
    "scrollbar": "#c8d8b0",
    "scrollbarHover": "#a8be88"
  },
  "theme": {
    "&": {
      "backgroundColor": "#f8fce8",
      "color": "#1a2410"
    },
    ".cm-gutters": {
      "backgroundColor": "#e8f0d5",
      "color": "#8a9d78",
      "borderRightColor": "#d4e0bf"
    },
    ".cm-cursor, .cm-dropCursor": {
      "borderLeft": "2px solid #d63f7a"
    },
    "&.cm-focused > .cm-scroller > .cm-selectionLayer .cm-selectionBackground, .cm-selectionBackground, .cm-content ::selection, .cm-searchMatch.cm-searchMatch.cm-searchMatch-selected": {
      "background": "rgba(214,63,122,0.18)"
    },
    "&.cm-focused .cm-matchingBracket, &.cm-focused .cm-nonmatchingBracket": {
      "margin": 0,
      "outline": "1px solid rgba(214,63,122,0.45)"
    },
    ".cm-activeLine": {
      "background": "rgba(214,63,122,0.06)"
    },
    ".cm-activeLineGutter": {
      "backgroundColor": "rgba(214,63,122,0.08)"
    },
    ".cm-selectionMatch.cm-selectionMatch, .cm-searchMatch.cm-searchMatch": {
      "outline": "1px solid rgba(180,83,9,0.32)",
      "margin": 0
    },
    ".cm-foldPlaceholder": {
      "backgroundColor": "rgba(214,63,122,0.12)",
      "borderColor": "rgba(214,63,122,0.35)",
      "color": "#1a2410"
    },
    ".cm-error-line": {
      "backgroundColor": "rgba(185,28,28,0.07)",
      "borderLeft": "3px solid #b91c1c"
    }
  },
  "highlightStyle": {
    ".tok-keyword": { "color": "#b8345a" },
    ".tok-literal": { "color": "#862557" },
    ".tok-typeName": { "color": "#5d8a3a" },
    ".tok-invalid": { "color": "#f8fce8", "backgroundColor": "#dc2626" },
    ".tok-string": { "color": "#b8843c" },
    ".tok-comment": { "fontStyle": "italic", "color": "#8a9d78" },
    ".tok-attributeValue": { "color": "#d63f7a", "fontStyle": "italic" },
    ".tok-number": { "color": "#b8843c" },
    ".tok-link": { "color": "#2a5a8a", "textDecoration": "underline" },
    ".tok-url": { "color": "#2a5a8a" },
    ".tok-strong": { "fontWeight": "bold" }
  }
}
