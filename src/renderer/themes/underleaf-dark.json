{
  "id": "underleaf-dark",
  "name": "Underleaf Dark",
  "dark": true,
  "chrome": {
    "bgApp": "#1a2332",
    "bgSidebar": "#1e293b",
    "bgPanel": "#0f172a",
    "bgCard": "#1e2d3d",
    "bgCardHover": "#243447",
    "bgToolbar": "#16213e",
    "bgInput": "#0f172a",
    "bgModal": "#1e293b",
    "bgOverlay": "rgba(0,0,0,0.6)",
    "brand": "#4CAF50",
    "brandDark": "#388E3C",
    "brandHover": "#43a047",
    "textPrimary": "#e2e8f0",
    "textSecondary": "#94a3b8",
    "textMuted": "#64748b",
    "textAccent": "#4ade80",
    "textError": "#f87171",
    "textWarning": "#fbbf24",
    "border": "#2d3f55",
    "borderLight": "#334155",
    "borderFocus": "#4CAF50",
    "error": "#ef4444",
    "warning": "#f59e0b",
    "success": "#22c55e",
    "info": "#3b82f6",
    "scrollbar": "#2d3f55",
    "scrollbarHover": "#3d5070"
  },
  "theme": {
    "&": {
      "backgroundColor": "#1a2332",
      "color": "#dde3ed"
    },
    ".cm-gutters": {
      "backgroundColor": "#16213e",
      "color": "#475569",
      "borderRightColor": "#2d3f55"
    },
    ".cm-cursor, .cm-dropCursor": {
      "borderLeft": "2px solid #4ade80"
    },
    "&.cm-focused > .cm-scroller > .cm-selectionLayer .cm-selectionBackground, .cm-selectionBackground, .cm-content ::selection, .cm-searchMatch.cm-searchMatch.cm-searchMatch-selected": {
      "background": "rgba(76,175,80,0.22)"
    },
    "&.cm-focused .cm-matchingBracket, &.cm-focused .cm-nonmatchingBracket": {
      "margin": 0,
      "outline": "1px solid rgba(76,175,80,0.45)"
    },
    ".cm-activeLine": {
      "background": "rgba(255,255,255,0.025)"
    },
    ".cm-activeLineGutter": {
      "backgroundColor": "rgba(76,175,80,0.1)"
    },
    ".cm-selectionMatch.cm-selectionMatch, .cm-searchMatch.cm-searchMatch": {
      "outline": "1px solid rgba(255,200,0,0.3)",
      "margin": 0
    },
    ".cm-foldPlaceholder": {
      "backgroundColor": "rgba(76,175,80,0.15)",
      "borderColor": "rgba(76,175,80,0.4)",
      "color": "#dde3ed"
    },
    ".cm-error-line": {
      "backgroundColor": "rgba(239,68,68,0.08)",
      "borderLeft": "3px solid #ef4444"
    }
  },
  "highlightStyle": {
    ".tok-tagName": { "color": "#dde3ed" },
    ".tok-keyword": { "color": "#34d399" },
    ".tok-literal": { "color": "#a78bfa" },
    ".tok-typeName": { "color": "#fb923c" },
    ".tok-invalid": { "color": "#dde3ed", "backgroundColor": "#ef4444" },
    ".tok-string": { "color": "#fbbf24" },
    ".tok-comment": { "fontStyle": "italic", "color": "#475569" },
    ".tok-attributeValue": { "color": "#86efac", "fontStyle": "italic" },
    ".tok-attributeName": { "color": "#60a5fa" },
    ".tok-variableName": { "color": "#fbbf24" },
    ".tok-number": { "color": "#fbbf24" },
    ".tok-link": { "color": "#60a5fa", "textDecoration": "underline" },
    ".tok-url": { "color": "#60a5fa" },
    ".tok-monospace": { "color": "#86efac" },
    ".tok-labelName": { "color": "#86efac" },
    ".tok-strong": { "fontWeight": "bold" },
    ".tok-emphasis": { "fontStyle": "italic" }
  }
}
