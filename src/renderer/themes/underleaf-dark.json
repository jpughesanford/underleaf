{
  "id": "underleaf-dark",
  "name": "Underleaf Dark",
  "dark": true,
  "chrome": {
    "bgApp": "#141b21",
    "bgSidebar": "#17202a",
    "bgPanel": "#0f1820",
    "bgCard": "#1c2932",
    "bgCardHover": "#21303a",
    "bgToolbar": "#15222a",
    "bgInput": "#0f1820",
    "bgModal": "#17202a",
    "bgOverlay": "rgba(0,0,0,0.6)",
    "brand": "#98c379",
    "brandDark": "#7fb069",
    "brandHover": "#b4d49a",
    "textPrimary": "#e8eede",
    "textSecondary": "#a5b3a0",
    "textMuted": "#6a786e",
    "textAccent": "#f3a5b6",
    "textError": "#f87171",
    "textWarning": "#f5e0a0",
    "border": "#2d3d3a",
    "borderLight": "#3a4844",
    "borderFocus": "#98c379",
    "error": "#ef4444",
    "warning": "#f59e0b",
    "success": "#98c379",
    "info": "#93c5fd",
    "scrollbar": "#2d3d3a",
    "scrollbarHover": "#3d4d48"
  },
  "theme": {
    "&": {
      "backgroundColor": "#141b21",
      "color": "#e8eede"
    },
    ".cm-gutters": {
      "backgroundColor": "#17202a",
      "color": "#4a5849",
      "borderRightColor": "#2d3d3a"
    },
    ".cm-cursor, .cm-dropCursor": {
      "borderLeft": "2px solid #98c379"
    },
    "&.cm-focused > .cm-scroller > .cm-selectionLayer .cm-selectionBackground, .cm-selectionBackground, .cm-content ::selection, .cm-searchMatch.cm-searchMatch.cm-searchMatch-selected": {
      "background": "rgba(152,195,121,0.22)"
    },
    "&.cm-focused .cm-matchingBracket, &.cm-focused .cm-nonmatchingBracket": {
      "margin": 0,
      "outline": "1px solid rgba(152,195,121,0.45)"
    },
    ".cm-activeLine": {
      "background": "rgba(243,165,182,0.04)"
    },
    ".cm-activeLineGutter": {
      "backgroundColor": "rgba(152,195,121,0.08)"
    },
    ".cm-selectionMatch.cm-selectionMatch, .cm-searchMatch.cm-searchMatch": {
      "outline": "1px solid rgba(245,224,160,0.32)",
      "margin": 0
    },
    ".cm-foldPlaceholder": {
      "backgroundColor": "rgba(152,195,121,0.14)",
      "borderColor": "rgba(152,195,121,0.4)",
      "color": "#e8eede"
    },
    ".cm-error-line": {
      "backgroundColor": "rgba(239,68,68,0.08)",
      "borderLeft": "3px solid #ef4444"
    }
  },
  "highlightStyle": {
    ".tok-keyword": { "color": "#98c379" },
    ".tok-literal": { "color": "#f5b079" },
    ".tok-typeName": { "color": "#f3a5b6" },
    ".tok-invalid": { "color": "#e8eede", "backgroundColor": "#ef4444" },
    ".tok-string": { "color": "#f5e0a0" },
    ".tok-comment": { "fontStyle": "italic", "color": "#5d6b65" },
    ".tok-attributeValue": { "color": "#c8d99e", "fontStyle": "italic" },
    ".tok-number": { "color": "#f5e0a0" },
    ".tok-link": { "color": "#93c5fd", "textDecoration": "underline" },
    ".tok-url": { "color": "#93c5fd" },
    ".tok-strong": { "fontWeight": "bold" }
  }
}
