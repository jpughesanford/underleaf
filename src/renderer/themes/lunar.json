{
  "id": "lunar",
  "name": "Lunar",
  "dark": true,
  "chrome": {
    "bgApp": "#2e3440",
    "bgSidebar": "#3b4252",
    "bgPanel": "#2e3440",
    "bgCard": "#3b4252",
    "bgCardHover": "#434c5e",
    "bgToolbar": "#292e3a",
    "bgInput": "#3b4252",
    "bgModal": "#3b4252",
    "bgOverlay": "rgba(0,0,0,0.55)",
    "brand": "#88c0d0",
    "brandDark": "#5e81ac",
    "brandHover": "#8fbcbb",
    "textPrimary": "#eceff4",
    "textSecondary": "#d8dee9",
    "textMuted": "#7b88a1",
    "textAccent": "#a3be8c",
    "textError": "#bf616a",
    "textWarning": "#ebcb8b",
    "border": "#4c566a",
    "borderLight": "#434c5e",
    "borderFocus": "#88c0d0",
    "error": "#bf616a",
    "warning": "#ebcb8b",
    "success": "#a3be8c",
    "info": "#81a1c1",
    "scrollbar": "#4c566a",
    "scrollbarHover": "#5e6f8f"
  },
  "theme": {
    "&": {
      "backgroundColor": "#2e3440",
      "color": "#eceff4"
    },
    ".cm-gutters": {
      "backgroundColor": "#292e3a",
      "color": "#616e88",
      "borderRightColor": "#3b4252"
    },
    ".cm-cursor, .cm-dropCursor": {
      "borderLeft": "2px solid #88c0d0"
    },
    "&.cm-focused > .cm-scroller > .cm-selectionLayer .cm-selectionBackground, .cm-selectionBackground, .cm-content ::selection, .cm-searchMatch.cm-searchMatch.cm-searchMatch-selected": {
      "background": "rgba(136,192,208,0.25)"
    },
    "&.cm-focused .cm-matchingBracket, &.cm-focused .cm-nonmatchingBracket": {
      "margin": 0,
      "outline": "1px solid rgba(136,192,208,0.45)"
    },
    ".cm-activeLine": {
      "background": "rgba(255,255,255,0.03)"
    },
    ".cm-activeLineGutter": {
      "backgroundColor": "rgba(136,192,208,0.08)"
    },
    ".cm-selectionMatch.cm-selectionMatch, .cm-searchMatch.cm-searchMatch": {
      "outline": "1px solid rgba(235,203,139,0.48)",
      "margin": 0
    },
    ".cm-foldPlaceholder": {
      "backgroundColor": "rgba(136,192,208,0.15)",
      "borderColor": "rgba(136,192,208,0.35)",
      "color": "#eceff4"
    },
    ".cm-error-line": {
      "backgroundColor": "rgba(191,97,106,0.14)",
      "borderLeft": "3px solid #bf616a"
    }
  },
  "highlightStyle": {
    ".tok-keyword": { "color": "#a3be8c" },
    ".tok-literal": { "color": "#b48ead" },
    ".tok-typeName": { "color": "#d08770" },
    ".tok-invalid": { "color": "#eceff4", "backgroundColor": "#bf616a" },
    ".tok-string": { "color": "#ebcb8b" },
    ".tok-comment": { "fontStyle": "italic", "color": "#616e88" },
    ".tok-attributeValue": { "color": "#8fbcbb", "fontStyle": "italic" },
    ".tok-number": { "color": "#ebcb8b" },
    ".tok-link": { "color": "#88c0d0", "textDecoration": "underline" },
    ".tok-url": { "color": "#88c0d0" },
    ".tok-strong": { "fontWeight": "bold" }
  }
}
