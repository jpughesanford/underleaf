{
  "id": "underleaf-light",
  "name": "Underleaf Light",
  "dark": false,
  "chrome": {
    "bgApp": "#f5f0e8",
    "bgSidebar": "#ede7dc",
    "bgPanel": "#e6dfd3",
    "bgCard": "#fdf8f2",
    "bgCardHover": "#f4ede4",
    "bgToolbar": "#2d2420",
    "bgInput": "#fdf8f2",
    "bgModal": "#fdf8f2",
    "bgOverlay": "rgba(0,0,0,0.45)",
    "brand": "#2e7d32",
    "brandDark": "#1b5e20",
    "brandHover": "#388e3c",
    "textPrimary": "#1c1410",
    "textSecondary": "#5a4e44",
    "textMuted": "#9d8e82",
    "textAccent": "#2e7d32",
    "textError": "#b91c1c",
    "textWarning": "#b45309",
    "border": "#d8cfc4",
    "borderLight": "#e3dbd0",
    "borderFocus": "#2e7d32",
    "error": "#dc2626",
    "warning": "#d97706",
    "success": "#2e7d32",
    "info": "#1d4ed8",
    "scrollbar": "#c5bcb0",
    "scrollbarHover": "#b0a89c"
  },
  "theme": {
    "&": {
      "backgroundColor": "#fdf8f2",
      "color": "#1c1410"
    },
    ".cm-gutters": {
      "backgroundColor": "#f5efe6",
      "color": "#a89a8e",
      "borderRightColor": "#ddd6ca"
    },
    ".cm-cursor, .cm-dropCursor": {
      "borderLeft": "2px solid #2e7d32"
    },
    "&.cm-focused > .cm-scroller > .cm-selectionLayer .cm-selectionBackground, .cm-selectionBackground, .cm-content ::selection, .cm-searchMatch.cm-searchMatch.cm-searchMatch-selected": {
      "background": "rgba(46,125,50,0.2)"
    },
    "&.cm-focused .cm-matchingBracket, &.cm-focused .cm-nonmatchingBracket": {
      "margin": 0,
      "outline": "1px solid rgba(46,125,50,0.45)"
    },
    ".cm-activeLine": {
      "background": "rgba(0,0,0,0.025)"
    },
    ".cm-activeLineGutter": {
      "backgroundColor": "rgba(46,125,50,0.08)"
    },
    ".cm-selectionMatch.cm-selectionMatch, .cm-searchMatch.cm-searchMatch": {
      "outline": "1px solid rgba(180,83,9,0.32)",
      "margin": 0
    },
    ".cm-foldPlaceholder": {
      "backgroundColor": "rgba(46,125,50,0.12)",
      "borderColor": "rgba(46,125,50,0.35)",
      "color": "#1c1410"
    },
    ".cm-error-line": {
      "backgroundColor": "rgba(185,28,28,0.07)",
      "borderLeft": "3px solid #b91c1c"
    }
  },
  "highlightStyle": {
    ".tok-tagName": { "color": "#1c1410" },
    ".tok-keyword": { "color": "#065f46" },
    ".tok-literal": { "color": "#6d28d9" },
    ".tok-typeName": { "color": "#b45309" },
    ".tok-invalid": { "color": "#fdf8f2", "backgroundColor": "#dc2626" },
    ".tok-string": { "color": "#0369a1" },
    ".tok-comment": { "fontStyle": "italic", "color": "#78716c" },
    ".tok-attributeValue": { "color": "#0c4a6e", "fontStyle": "italic" },
    ".tok-attributeName": { "color": "#1d4ed8" },
    ".tok-variableName": { "color": "#0369a1" },
    ".tok-number": { "color": "#0369a1" },
    ".tok-link": { "color": "#1d4ed8", "textDecoration": "underline" },
    ".tok-url": { "color": "#1d4ed8" },
    ".tok-monospace": { "color": "#0c4a6e" },
    ".tok-labelName": { "color": "#0c4a6e" },
    ".tok-strong": { "fontWeight": "bold" },
    ".tok-emphasis": { "fontStyle": "italic" }
  }
}
