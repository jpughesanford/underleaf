{
  "name": "underleaf",
  "version": "0.1.0",
  "description": "Offline Overleaf-compatible LaTeX IDE with git integration",
  "main": "out/main/index.js",
  "author": "Underleaf",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint src electron --ext .ts,.tsx",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run lint && npm run test",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.43.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.1",
    "codemirror-lang-latex": "^0.4.1",
    "dictionary-de": "^3.0.0",
    "dictionary-en": "^4.0.0",
    "dictionary-en-gb": "^3.0.0",
    "dictionary-es": "^4.0.0",
    "dictionary-fr": "^3.0.0",
    "dictionary-it": "^2.0.0",
    "dictionary-nl": "^2.0.0",
    "dictionary-pl": "^2.0.0",
    "dictionary-pt-br": "^2.0.1",
    "dictionary-ru": "^3.0.0",
    "dictionary-sv": "^4.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "hunspell-asm": "4.0.2",
    "lucide-react": "^1.16.0",
    "pdfjs-dist": "^4.9.155",
    "simple-git": "^3.27.0"
  },
  "comments": {
    "pinned": "hunspell-asm and emscripten-wasm-loader are pinned to exact versions because patches/ targets those exact versions; a bump would silently stop applying and break spell check."
  },
  "overrides": {
    "emscripten-wasm-loader": "3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "patch-package": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.underleaf.app",
    "productName": "Underleaf",
    "icon": "resources/icon.icns",
    "files": [
      "out/**"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "afterPack": "electron/afterPack.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.icns",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
